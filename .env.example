# ===========================================
# MRC Lead Management System - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env with real values to git.
# Edge Function secrets (SUPABASE_SERVICE_ROLE_KEY, RESEND_API_KEY, etc.)
# are set in the Supabase Dashboard, NOT here.
# ===========================================

# --- Supabase (Required) ---
# Get from: https://supabase.com/dashboard > Project Settings > API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Google Maps (Optional — address autocomplete & travel time) ---
# Get from: https://console.cloud.google.com/ > APIs & Services > Credentials
VITE_GOOGLE_MAPS_API_KEY=

# --- Sentry Error Tracking (Optional — error monitoring) ---
# Get DSN from: https://sentry.io > Project Settings > Client Keys (DSN)
VITE_SENTRY_DSN=

# --- Sentry Build-Time (Optional — source map uploads) ---
# These are NOT prefixed with VITE_ so they are NOT exposed to the browser.
# Get from: https://sentry.io > Settings > Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
