# Copy to .env.test (gitignored) and fill in before running Playwright.
# Do NOT commit real credentials.

ADMIN_EMAIL=
ADMIN_PASSWORD=
TECH_EMAIL=
TECH_PASSWORD=

# Optional — enables additional flow assertions when populated.
# TEST_LEAD_ID=
# TEST_INSPECTION_ID=
# REVISION_LEAD_ID=
# INVOICED_LEAD_ID=
# PAID_LEAD_ID=
# FINISHED_LEAD_ID=

# Override to run against production instead of local dev:
# PLAYWRIGHT_BASE_URL=https://your-prod-url.vercel.app
